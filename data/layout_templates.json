{
  "Landing Page": "<div className=\"min-h-screen bg-background\">\n  <NavBar />\n  <main>\n    {/* Hero */}\n    <section className=\"py-24 sm:py-32\">\n      <div className=\"mx-auto max-w-7xl px-6 lg:px-8 text-center\">\n        <h1 className=\"text-4xl font-bold sm:text-6xl\">Headline</h1>\n        <p className=\"mt-6 text-lg text-muted-foreground max-w-2xl mx-auto\">Subheadline</p>\n        <div className=\"mt-10 flex justify-center gap-4\">\n          <Button size=\"lg\">Get Started</Button>\n          <Button variant=\"outline\" size=\"lg\">Learn More</Button>\n        </div>\n      </div>\n    </section>\n    {/* Social Proof */}\n    <section className=\"border-y bg-muted/50 py-12\">\n      <LogoBar />\n    </section>\n    {/* Features */}\n    <section className=\"py-24\">\n      <FeatureGrid columns={3} />\n    </section>\n    {/* Testimonials */}\n    <section className=\"bg-muted/50 py-24\">\n      <TestimonialCarousel />\n    </section>\n    {/* CTA */}\n    <section className=\"py-24 text-center\">\n      <CTASection />\n    </section>\n  </main>\n  <Footer />\n</div>",
  "Dashboard": "<div className=\"flex h-screen\">\n  {/* Sidebar */}\n  <aside className=\"hidden w-64 border-r bg-background md:block\">\n    <Sidebar />\n  </aside>\n  {/* Main */}\n  <main className=\"flex-1 overflow-y-auto\">\n    <header className=\"sticky top-0 z-40 border-b bg-background/95 backdrop-blur\">\n      <div className=\"flex h-14 items-center px-6\">\n        <h1 className=\"text-lg font-semibold\">Dashboard</h1>\n        <div className=\"ml-auto flex items-center gap-4\">\n          <SearchBar />\n          <Avatar />\n        </div>\n      </div>\n    </header>\n    <div className=\"p-6 space-y-6\">\n      {/* KPI Cards */}\n      <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-4\">\n        <StatCard />\n      </div>\n      {/* Charts */}\n      <div className=\"grid gap-4 md:grid-cols-2\">\n        <Card><Chart /></Card>\n        <Card><Chart /></Card>\n      </div>\n      {/* Table */}\n      <Card><DataTable /></Card>\n    </div>\n  </main>\n</div>"
